@model SampleProjects.Models.ViewModels.ProductModel


<div class="row">
	<div class="col-md-4">
		<form asp-action="Create">
			<div asp-validation-summary="ModelOnly" class="text-danger"></div>
			<div class="form-group">
				<label asp-for="Name" class="control-label"></label>
				<input asp-for="Name" class="form-control" />
				<span asp-validation-for="Name" class="text-danger"></span>
			</div>
			<div class="form-group">
				<label asp-for="StockQuantity" class="control-label"></label>
				<input asp-for="StockQuantity" class="form-control" />
				<span asp-validation-for="StockQuantity" class="text-danger"></span>
			</div>
			<div class="form-group">
				<label asp-for="UnitId" class="control-label"></label>
				<select asp-for="UnitId" class="form-control" asp-items="ViewBag.UnitList">
					<option value="">---انتخاب واحد اندازه گیری---</option>
				</select>
			</div>
			<div class="form-group">
				<label asp-for="Description" class="control-label"></label>
				<input asp-for="Description" class="form-control" />
				<span asp-validation-for="Description" class="text-danger"></span>
			</div>
			<div class="form-group">
				<div class="input-group">
					<div class="custom-file">
						<label asp-for="ImageFile" class="custom-file-label"></label>
						<input asp-for="ImageFile" id="files" class="custom-file-input" type="file" />
						<span asp-validation-for="ImageFile" class="text-danger"></span>
					</div>
				</div>
			</div>
			<div class="form-group">
				<input type="submit" value="Create" class="btn btn-primary" />
			</div>
		</form>
	</div>
</div>

<div>
	<a asp-action="Index">Back to List</a>
</div>

